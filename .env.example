# AWS Configuration
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1

# Bedrock Configuration
BEDROCK_REGION=us-east-1
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1
LLM_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Knowledge Base Configuration (set after deployment)
KNOWLEDGE_BASE_ID=

# Vector Store Configuration
VECTOR_STORE_TYPE=opensearch
OPENSEARCH_ENDPOINT=
OPENSEARCH_INDEX=psalm-embeddings

# Retrieval Configuration
MAX_RESULTS=5
MIN_RESULTS=3
SIMILARITY_THRESHOLD=0.7

# Lambda Configuration (Requirement 2.3, 7.4)
LAMBDA_TIMEOUT_SECONDS=10
REQUEST_TIMEOUT_SECONDS=5

# Retry Configuration (Requirement 8.2)
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2.0

# Input Validation (Requirement 1.1)
MAX_INPUT_SENTENCES=2

# Logging Configuration
LOG_LEVEL=INFO
SERVICE_NAME=psalm-recommendation-rag

# Privacy Configuration (Requirement 9.2)
ENABLE_PII_LOGGING=false

# CDK Deployment Configuration
CDK_DEFAULT_ACCOUNT=${AWS_ACCOUNT_ID}
CDK_DEFAULT_REGION=${AWS_REGION}
